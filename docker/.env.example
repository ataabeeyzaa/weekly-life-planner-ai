# docker/.env — n8n container için ENV
# Bu dosyayı kopyala -> docker/.env yap, gerçek değerleri yaz
# docker/.env GİT'E KOMMİT EDİLMEZ (.gitignore'da listeli)

# ngrok başlatınca verdiği https URL
# Örn: https://abc123.ngrok-free.app/
N8N_WEBHOOK_URL=https://your-ngrok-subdomain.ngrok-free.app/

# n8n credential şifreleme anahtarı (rastgele 32 karakter)
# Bir kere üret, asla değiştirme — değiştirirsen tüm credential'lar bozulur
N8N_ENCRYPTION_KEY=change-this-to-32-random-chars-please
