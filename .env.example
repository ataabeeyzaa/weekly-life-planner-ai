# weekly-life-planner-ai — Çevre Değişkenleri Şablonu
# Bu dosyayı kopyala -> .env yap, gerçek değerleri yaz.
# .env GİT'E KOMMİT EDİLMEZ (.gitignore'da listeli)

# === Supabase ===
# Supabase Dashboard > Settings > API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Supabase Dashboard > Settings > Database (Connection info)
SUPABASE_DB_PASSWORD=your-db-password
SUPABASE_DB_HOST=db.your-project-ref.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres

# === Telegram ===
# BotFather > /newbot çıktısı
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ
TELEGRAM_BOT_USERNAME=BeyzaPlanlaBot

# === Google Gemini (PRIMARY — ücretsiz, kart gerekmez) ===
# aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-1.5-flash

# === OpenAI (fallback, kullanmıyorsak boş bırak) ===
# platform.openai.com > API Keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# === n8n ===
# ngrok start ettiğinde değişir (free tier)
N8N_WEBHOOK_URL=https://your-ngrok-subdomain.ngrok-free.app/
